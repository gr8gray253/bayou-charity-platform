{
  "expo": {
    "name": "Bayou Charity",
    "slug": "bayou-charity",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "bayoucharity",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d2b3e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "org.bayoucharity.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0d2b3e"
      },
      "package": "org.bayoucharity.app"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#0d2b3e"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
